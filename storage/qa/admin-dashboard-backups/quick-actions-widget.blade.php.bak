            <div class="text-xs text-gray-500">Open orders list</div>
        </a>

        <a href="/admin/resources/reservations" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
            <div class="text-sm font-semibold">View Reservations</div>
