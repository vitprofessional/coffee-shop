<!-- ACTIVE QUICK ACTIONS WIDGET -->
<div class="bg-white rounded shadow p-4">
    <div class="text-sm font-medium mb-3">Quick Actions</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
        <a href="/admin/resources/menu-items/create" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
            <div class="text-sm font-semibold">Add Menu Item</div>
            <div class="text-xs text-gray-500">Create a new menu item</div>
        </a>

        <a href="/admin/resources/events/create" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
            <div class="text-sm font-semibold">Add Event</div>
            <div class="text-xs text-gray-500">Schedule a new event</div>
        </a>

        <a href="/admin/resources/blog-posts/create" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
            <div class="text-sm font-semibold">Add Journal Post</div>
