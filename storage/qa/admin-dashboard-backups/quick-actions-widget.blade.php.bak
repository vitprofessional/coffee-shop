        </a>

        <a href="/admin/resources/galleries/create" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
            <div class="text-sm font-semibold">Add Gallery Image</div>
            <div class="text-xs text-gray-500">Upload images</div>
        </a>

        <a href="/admin/resources/orders" class="block p-4 rounded-xl border bg-white hover:bg-gray-50">
